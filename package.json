{
  "name": "check-leaks-passwords",
  "version": "0.0.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "description": "Check if passwords from CSV or JSON file exist in a HIBP leaked hashes file. Supports CSV and JSON input/output formats.",
  "main": "index.js",
  "scripts": {
    "start": "ts-node index.ts",
    "lint": "eslint --ext .js,.ts index.ts src config tests",
    "lint-fix": "eslint --ext .js,.ts index.ts src config tests --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fast-csv": "^4.3.6",
    "hasha": "^5.2.0"
  },
  "devDependencies": {
    "@tsconfig/node18": "^18.2.6",
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^3.9.1",
    "@typescript-eslint/parser": "^3.9.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^7.2.0",
    "eslint-config-airbnb-base": "^14.2.0",
    "eslint-plugin-import": "^2.21.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
